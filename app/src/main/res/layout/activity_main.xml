<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.MainActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        >
        <Button
            android:id="@+id/btn_jump_second"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="跳转SecondActivity"
            >
        </Button>
        <Button
            android:id="@+id/btn_jump_single_top"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="跳转singleTop页面"
            >
        </Button>
        <Button
            android:id="@+id/btn_jump_single_task"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="跳转singleTask"
            >
        </Button>
        <Button
            android:id="@+id/btn_jump_with_data"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="带参数跳转"
            >
        </Button>
        <Button
            android:id="@+id/btn_jump_gas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="跳转油号选择页面"
            >
        </Button>
        <Button
            android:id="@+id/btn_jump_gas_list"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="跳转加油列表页面"
            >
        </Button>
        <Button
            android:id="@+id/btn_jump_charging_list"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="跳转到充电列表页面"
            >
        </Button>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>